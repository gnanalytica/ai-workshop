{
  "enabledPlugins": {
    "supabase@claude-plugins-official": true,
    "vercel@claude-plugins-official": true
  },
  "permissions": {
    "deny": [
      "Edit(.env)",
      "Edit(.env.local)",
      "Edit(.env.production)",
      "Edit(.env.development)",
      "Edit(.env.preview)",
      "Edit(web/.env)",
      "Edit(web/.env.local)",
      "Edit(web/.env.production)",
      "Edit(web/.env.development)",
      "Edit(web/.env.preview)",
      "Write(.env)",
      "Write(.env.local)",
      "Write(.env.production)",
      "Write(.env.development)",
      "Write(.env.preview)",
      "Write(web/.env)",
      "Write(web/.env.local)",
      "Write(web/.env.production)",
      "Write(web/.env.development)",
      "Write(web/.env.preview)",
      "Edit(supabase/migrations/000*_*.sql)",
      "Edit(supabase/migrations/001*_*.sql)",
      "Edit(supabase/migrations/002*_*.sql)",
      "Edit(supabase/migrations/003*_*.sql)",
      "Edit(supabase/migrations/004*_*.sql)",
      "Edit(supabase/migrations/005*_*.sql)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/verify-web.sh"
          }
        ]
      }
    ]
  }
}
